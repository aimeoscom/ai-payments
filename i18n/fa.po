#, php-format
msgid "Method \"%1$s\" for provider not available"
msgstr "متد \"%1$s\" برای فراهم کننده موجود نیست"

#, php-format
msgid "No Stripe customer data available for customer ID \"%1$s\""
msgstr "هیچ داده‌ای از مشتریان Stripe برای شناسه مشتری «%1$s» در دسترس نیست."

#, php-format
msgid "No Stripe payment method available for customer ID \"%1$s\""
msgstr "هیچ روش پرداخت Stripe برای شناسه مشتری \"%1$s\" در دسترس نیست."

#, php-format
msgid "No payment token available for customer ID \"%1$s\""
msgstr "برای مشتری با شناسه \"%1$s\" هیچ توکن پرداختی موجود نیست"

#, php-format
msgid "No reoccurring payment data available for customer ID \"%1$s\""
msgstr "اطلاعات پرداخت دوباره ای برای مشتری با شناسه \"%1$s\" موجود نیست"

#, php-format
msgid "Order %1$s"
msgstr "سفارش %1$s"

msgid "PayPalPlus approval URL not available"
msgstr "URL تأیید PayPalPlus در دسترس نیست"

msgid "PayPalPlus requires the country ID of the user"
msgstr "PayPalPlus به شناسه کشور کاربر نیاز دارد."

#, php-format
msgid "Token based payment failed with code \"%1$s\" and message \"%2$s\": %3$s"
msgstr "پرداخت مبتنی بر توکن با کد \"%1$s\" و پیام \"%2$s\" ناموفق بود: %3$s"

#, php-format
msgid "Token based payment failed: %1$s"
msgstr "پرداخت بر پایه توکن ناموفق:%1$s"

#, php-format
msgid "Token based payment incomplete: %1$s"
msgstr "پرداخت مبتنی بر توکن ناقص است: %1$s"

#, php-format
msgid "Unexpected redirect: %1$s"
msgstr "تغییر مسیر غیرمنتظره:%1$s"
