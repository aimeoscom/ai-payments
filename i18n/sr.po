#, php-format
msgid "Method \"%1$s\" for provider not available"
msgstr "Метод \"%1$s\" за провајдера није доступан"

#, php-format
msgid "No Stripe customer data available for customer ID \"%1$s\""
msgstr "Нема доступних података о купцу за ID \"%1$s\""

#, php-format
msgid "No Stripe payment method available for customer ID \"%1$s\""
msgstr "Ниједан Stripe начин плаћања није доступан за ID купца \"%1$s\""

#, php-format
msgid "No payment token available for customer ID \"%1$s\""
msgstr "За кориснички ИД \"%1$s\" није доступан токен за плаћање."

#, php-format
msgid "No reoccurring payment data available for customer ID \"%1$s\""
msgstr "Нема доступних података о поновним уплатама за ИД купца \"%1$s\""

#, php-format
msgid "Order %1$s"
msgstr "Наручите %1$s"

msgid "PayPalPlus approval URL not available"
msgstr "URL за одобрење PayPalPlus-а није доступан"

msgid "PayPalPlus requires the country ID of the user"
msgstr "PayPalPlus захтева идентификациони број земље корисника."

#, php-format
msgid "Token based payment failed with code \"%1$s\" and message \"%2$s\": %3$s"
msgstr ""
"Плаћање засновано на токенима није успело са кодом \"%1$s\" и поруком "
"\"%2$s\": %3$s"

#, php-format
msgid "Token based payment failed: %1$s"
msgstr "Плаћање засновано на токену није успело: %1$s"

#, php-format
msgid "Token based payment incomplete: %1$s"
msgstr "Плаћање засновано на токенима није завршено: %1$s"

#, php-format
msgid "Unexpected redirect: %1$s"
msgstr "Неочекивано преусмеравање: %1$s"
