#, php-format
msgid "Method \"%1$s\" for provider not available"
msgstr "Phương thức \"%1$s\" không khả dụng cho nhà cung cấp."

#, php-format
msgid "No Stripe customer data available for customer ID \"%1$s\""
msgstr "Không có dữ liệu khách hàng của Stripe cho ID khách hàng \"%1$s\""

#, php-format
msgid "No Stripe payment method available for customer ID \"%1$s\""
msgstr ""
"Không có phương thức thanh toán Stripe khả dụng cho ID khách hàng \"%1$s\""

#, php-format
msgid "No payment token available for customer ID \"%1$s\""
msgstr "Không có mã thanh toán khả dụng cho ID khách hàng \"%1$s\""

#, php-format
msgid "No reoccurring payment data available for customer ID \"%1$s\""
msgstr "Không có dữ liệu thanh toán định kỳ cho ID khách hàng \"%1$s\""

#, php-format
msgid "Order %1$s"
msgstr "Đặt hàng %1$s"

msgid "PayPalPlus approval URL not available"
msgstr "URL phê duyệt PayPalPlus không khả dụng"

msgid "PayPalPlus requires the country ID of the user"
msgstr "PayPalPlus yêu cầu mã quốc gia của người dùng."

#, php-format
msgid "Token based payment failed with code \"%1$s\" and message \"%2$s\": %3$s"
msgstr "Thanh toán bằng token đã thất bại với mã \"%1$s\" và thông báo \"%2$s\": %3$s"

#, php-format
msgid "Token based payment failed: %1$s"
msgstr "Thanh toán bằng token không thành công: %1$s"

#, php-format
msgid "Token based payment incomplete: %1$s"
msgstr "Thanh toán bằng token chưa hoàn tất: %1$s"

#, php-format
msgid "Unexpected redirect: %1$s"
msgstr "Chuyển hướng không mong muốn: %1$s"
