#, php-format
msgid "Method \"%1$s\" for provider not available"
msgstr "Metoden «%1$s» er ikke tilgjengelig for leverandøren"

#, php-format
msgid "No Stripe customer data available for customer ID \"%1$s\""
msgstr "Det finnes ingen Stripe-kundedata for kunde-ID «%1$s»"

#, php-format
msgid "No Stripe payment method available for customer ID \"%1$s\""
msgstr "Det finnes ingen Stripe-betalingsmåte for kunde-ID «%1$s»"

#, php-format
msgid "No payment token available for customer ID \"%1$s\""
msgstr "Det finnes ingen betalingstoken for kunde-ID «%1$s»"

#, php-format
msgid "No reoccurring payment data available for customer ID \"%1$s\""
msgstr ""
"Det finnes ingen opplysninger om gjentatte betalinger for kunde-ID «%1$s»"

#, php-format
msgid "Order %1$s"
msgstr "Bestill %1$s"

msgid "PayPalPlus approval URL not available"
msgstr "URL-adressen for godkjenning av PayPalPlus er ikke tilgjengelig"

msgid "PayPalPlus requires the country ID of the user"
msgstr "PayPalPlus krever brukerens landskode"

#, php-format
msgid "Token based payment failed with code \"%1$s\" and message \"%2$s\": %3$s"
msgstr ""
"Tokenbasert betaling mislyktes med koden «%1$s» og meldingen «%2$s»: %3$s"

#, php-format
msgid "Token based payment failed: %1$s"
msgstr "Tokenbasert betaling mislyktes: %1$s"

#, php-format
msgid "Token based payment incomplete: %1$s"
msgstr "Tokenbasert betaling fullført: %1$s"

#, php-format
msgid "Unexpected redirect: %1$s"
msgstr "Uventet viderekobling: %1$s"
